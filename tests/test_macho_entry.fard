import("../src/orgntr_prim/macho_emit") as macho
import("std/list") as list

fn u32le(bs, off) {
  list.get(bs, off) +
  list.get(bs, off + 1) * 256 +
  list.get(bs, off + 2) * 65536 +
  list.get(bs, off + 3) * 16777216
}

test "entry stub is valid Mach-O magic" {
  let bs = macho.emit_entry_stub() in
  u32le(bs, 0) == 4277009103
}

test "entry stub text is 17 bytes" {
  let bs = macho.emit_entry_stub() in
  // text size field at section header offset 144
  let lo = list.get(bs, 144) in
  lo == 17
}

test "entry stub text starts with push rbp" {
  let bs = macho.emit_entry_stub() in
  list.get(bs, 320) == 85
}

test "entry stub has call placeholder at offset 4" {
  let bs = macho.emit_entry_stub() in
  list.get(bs, 324) == 232 &&
  list.get(bs, 325) == 0 &&
  list.get(bs, 326) == 0 &&
  list.get(bs, 327) == 0 &&
  list.get(bs, 328) == 0
}

test "entry stub has mov rdi rax then call at offset 9" {
  let bs = macho.emit_entry_stub() in
  list.get(bs, 329) == 72 &&
  list.get(bs, 330) == 137 &&
  list.get(bs, 331) == 199 &&
  list.get(bs, 332) == 232
}

test "entry stub ncmds is 4" {
  let bs = macho.emit_entry_stub() in
  u32le(bs, 16) == 4
}

test "entry stub is nonempty" {
  list.len(macho.emit_entry_stub()) > 320
}
