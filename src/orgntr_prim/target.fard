fn x86_64_apple_darwin() {
  {
    triple: "x86_64-apple-darwin",
    object_format: "MachO",
    arch: "x86_64",
    endian: "little",
    abi: "sysv",
    platform_load_command: "LC_BUILD_VERSION",
    minos: "11.0.0",
    sdk: "13.0.0",
    entry_symbol: "fard_main",
    runtime_staticlib: "liborgntr_rt.a"
  }
}

fn target_name(t) { t.triple }

export { x86_64_apple_darwin, target_name }
