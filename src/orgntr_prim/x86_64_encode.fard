// fard_alloc(rdi=size) -> rax=ptr
// Bump allocator using __DATA segment
// heap_bump_ptr is at data_vmaddr (0x100002000)
// Returns current bump ptr, advances by size (rounded up to 8)
fn fard_alloc_stub(bump_ptr_vmaddr) {
  // mov rax, [rip + offset_to_bump_ptr]  -- load bump ptr addr
  // We use absolute addressing via mov rax, imm64
  // mov rcx, bump_ptr_vmaddr (absolute)
  // mov rax, [rcx]           -- load current bump ptr value
  // mov rdx, rax             -- save return value
  // add rax, rdi             -- advance by requested size
  // add rax, 7               -- round up
  // and rax, -8              -- align to 8
  // mov [rcx], rax           -- store new bump ptr
  // mov rax, rdx             -- return old bump ptr
  // ret
  let bump_abs = bump_ptr_vmaddr in
  list.concat([
    [72, 184],                           // REX.W mov rax, imm64
    le64(bump_abs),                      // absolute address of bump ptr
    [72, 139, 8],                        // mov rcx, [rax]  -- load bump ptr
    [72, 137, 202],                      // mov rdx, rcx    -- save return val
    [72, 1, 249],                        // add rcx, rdi    -- advance
    [72, 131, 193, 7],                   // add rcx, 7      -- round up
    [72, 131, 225, 248],                 // and rcx, -8     -- align
    [72, 137, 8],                        // mov [rax], rcx  -- store new bump
    [72, 137, 208],                      // mov rax, rdx    -- return old ptr
    [195]                                // ret
  ])
}
